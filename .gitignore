# Ignore everything by default and then whitelist what should be tracked
/*

# Keep repo metadata
!.gitignore

# Track build script and source tree
!build.tcl
!build.sh
!run_jtag.sh
!run_jtag.tcl
!configs/
!configs/**
!src/
!src/**

# Track web upload helpers (but keep web content untracked by default)
!web/
web/**
!web/upload*
!web/assets/
!web/assets/**

# Editor metadata
src/.obsidian/
src/.obsidian/**

# Python caches
**/__pycache__/
**/*.pyc

# Keep GitHub workflows if added later
!.github/
!.github/**
