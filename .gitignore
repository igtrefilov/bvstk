# Ignore everything by default and then whitelist what should be tracked
/*

# Keep repo metadata
!.gitignore

# Track scripts and source tree
!scripts/
!scripts/**
!configs/
!configs/**
!src/
!src/**

# Top-level docs
!README.md

# VSCode project settings (for Xilinx/Vitis navigation setup)
!.vscode/
!.vscode/**

# Local generated compilation database (generated per-machine, keep untracked)
compile_commands.json

# Track web upload helpers (but keep web content untracked by default)
!web/
web/**
!web/upload*
!web/assets/
!web/assets/**

# Documentation
!docs/
!docs/**

# Editor metadata
src/.obsidian/
src/.obsidian/**
docs/.obsidian/
docs/.obsidian/**

# XSCT/Vitis generated local metadata inside script directories
scripts/vitis/.Xil/
scripts/vitis/.Xil/**

# Python caches
**/__pycache__/
**/*.pyc

# Keep GitHub workflows if added later
!.github/
!.github/**
